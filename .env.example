# ─── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_56shkhk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Messaging channels (add the ones you need) ───────────────────────────────
TELEGRAM_BOT_TOKEN=7412345678:AAFyourBotTokenHere

# Optional: Slack
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token   # for Socket Mode

# Optional: WhatsApp via Twilio
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── LLM providers (add as needed) ───────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key

# ─── Infrastructure ───────────────────────────────────────────────────────────
# Defaults to SQLite; set to postgres URL for production
DATABASE_URL=sqlite+aiosqlite:///orchid.db

# Leave unset to use in-memory queue; set for Redis-backed async messaging
# REDIS_URL=redis://localhost:6379

# For Telegram webhook mode (requires public HTTPS URL, e.g. from ngrok)
# WEBHOOK_URL=https://your-ngrok-domain.ngrok-free.app

# ChromaDB host (leave unset for local file persistence)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
